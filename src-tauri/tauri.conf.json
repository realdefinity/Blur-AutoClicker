{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CometClicker",
  "version": "3.5.0",
  "identifier": "com.cometclicker.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run vite",
    "beforeBuildCommand": "npm run frontend:build",
    "removeUnusedCommands": true
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "CometClicker",
        "width": 500,
        "height": 150,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "maximizable": false,
        "shadow": false
      },
      {
        "label": "overlay",
        "url": "overlay.html",
        "title": "Overlay",
        "fullscreen": true,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true,
        "focusable": false,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Blur009/Blur-AutoClicker/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDIyREY0RTc2QTU4Qjc1N0UKUldSK2RZdWxkazdmSW1IQmI4ZVMwOTRzWnBiVENhMFNYMFRtN0V4R3N0Q2JXQUdqM2t4VnRnNUYK"
    },
    "bundle": {
      "active": true,
      "targets": "nsis",
      "createUpdaterArtifacts": true,
      "publisher": "CometClicker",
      "copyright": "Copyright (c) CometClicker contributors",
      "category": "Utility",
      "shortDescription": "CometClicker — accurate, configurable auto clicker with a modern purple-blue UI.",
      "longDescription": "Performance-focused auto clicker with global hotkeys, optional overlay, and advanced timing. Fork branding of the Blur project. Licensed under GPLv3.",
      "homepage": "https://github.com/Blur009/Blur-AutoClicker",
      "icon": ["icons/icon.ico"],
      "windows": {
        "webviewInstallMode": {
          "type": "embedBootstrapper",
          "silent": true
        },
        "nsis": {
          "compression": "zlib"
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "createUpdaterArtifacts": true,
    "icon": ["icons/icon.ico"],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper",
        "silent": true
      }
    }
  }
}
